# ── 로컬 개발 ──────────────────────────────────────────
# DATABASE_URL 미설정 시 SQLite(lotto.db) 자동 사용
# DB_PATH=./lotto.db

# ── 프로덕션 (Render 환경변수에 설정) ────────────────────
# Neon PostgreSQL 연결 문자열
# DATABASE_URL=postgresql://user:password@host/dbname

# Vercel 프론트엔드 URL (CORS 허용)
# FRONTEND_URL=https://your-app.vercel.app

# GitHub Actions 갱신 API 인증 토큰 (임의 문자열)
# UPDATE_TOKEN=your-secret-token
